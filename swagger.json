{
  "openapi": "3.0.0",
  "info": {
    "title": "Weather API",
    "version": "1.0.0"
  },
  "paths": {
    "/api/weather": {
      "get": {
        "tags": ["Weather"],
        "summary": "Retrieve weather of a specific city",
        "parameters": [
          {
            "in": "query",
            "name": "city",
            "schema": { "type": "string" },
            "required": true,
            "description": "City for which weather needs to be retrieved"
          }
        ],
        "responses": {
          "200": {
            "description": "Weather data retrieved",
            "content": {
              "application/json": {
                "example": {
                  "city": "Amsterdam",
                  "temperature": 92.4,
                  "humidity": 25.9,
                  "conditions": "Clear"
                }
              }
            }
          },
          "400": {
            "description": "Failed to retrieve weather data"
          }
        }
      }
    }
  },"tags":[
    {"name":"Weather","description":"Opeartion for retreving weather data for a specific data"}
  ]
}